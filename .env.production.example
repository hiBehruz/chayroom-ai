# Production .env for the self-hosted (Docker Compose) deploy.
# Copy this file to `.env` on the server and fill in real values.
# NEVER commit real secrets.

# --- Database (Docker Postgres) ---
# Only set the password here. docker-compose builds DATABASE_URL automatically as
#   postgres://chayroom:${POSTGRES_PASSWORD}@postgres:5432/chayroom
# and injects it into the nuxt + migrate containers, so you do NOT set DATABASE_URL.
POSTGRES_PASSWORD=

# --- Cache ---
# REDIS_URL is wired automatically by docker-compose (redis://redis:6379). Leave unset.

# --- App ---
NUXT_PUBLIC_APP_URL=https://chayroom.uz
NUXT_PUBLIC_SUPPORT_USERNAME=

# --- Telegram auth/bot ---
NUXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NUXT_TELEGRAM_BOT_TOKEN=

# --- OpenAI ---
NUXT_OPENAI_API_KEY=

# --- Cloudflare R2 (media storage) ---
NUXT_R2_ACCOUNT_ID=
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=
NUXT_R2_BUCKET_NAME=
NUXT_R2_PUBLIC_URL=

# --- Sentry ---
NUXT_PUBLIC_SENTRY_DSN=

# --- Tribute (payments) ---
NUXT_TRIBUTE_API_KEY=
NUXT_PUBLIC_TRIBUTE_TIER_1_MONTH_URL=
NUXT_PUBLIC_TRIBUTE_TIER_3_MONTH_URL=
NUXT_PUBLIC_TRIBUTE_TIER_6_MONTH_URL=

# --- Admin authorization ---
# Comma-separated numeric Telegram ids allowed into the admin panel.
NUXT_ADMIN_TELEGRAM_IDS=
# Random secret, >= 32 chars. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(24).toString('base64url'))"
NUXT_ADMIN_SESSION_PASSWORD=
# Share the admin session cookie across apex + subdomains.
NUXT_ADMIN_COOKIE_DOMAIN=.chayroom.uz
